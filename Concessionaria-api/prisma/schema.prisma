generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model clientes {
  id            Int          @id @default(autoincrement())
  nome          String?      @db.VarChar(255)
  telefone      String?      @db.VarChar(255)
  cpf           String?      @db.VarChar(255)
  cnh           String?      @db.VarChar(255)
  criado_em     DateTime     @default(now()) @db.Timestamp(0)
  atualizado_em DateTime     @default(now()) @db.Timestamp(0)
  deletado_em   DateTime?    @db.Timestamp(0)
  enderecos     enderecos[]
  orcamentos    orcamentos[]
  veiculos      veiculos[]
}

model departamentos {
  id            Int        @id @default(autoincrement())
  nome          String?    @db.VarChar(255)
  criado_em     DateTime   @default(now()) @db.Timestamp(0)
  atualizado_em DateTime   @default(now()) @db.Timestamp(0)
  deletado_em   DateTime?  @db.Timestamp(0)
  veiculos      veiculos[]
}

model enderecos {
  id            Int       @id @default(autoincrement())
  id_cliente    Int?
  cep           String?   @db.VarChar(255)
  logradouro    String?   @db.VarChar(255)
  bairro        String?   @db.VarChar(255)
  uf            String?   @db.VarChar(255)
  numero        String?   @db.VarChar(255)
  cidade        String?   @db.VarChar(255)
  criado_em     DateTime  @default(now()) @db.Timestamp(0)
  atualizado_em DateTime  @default(now()) @db.Timestamp(0)
  deletado_em   DateTime? @db.Timestamp(0)
  clientes      clientes? @relation(fields: [id_cliente], references: [id], onDelete: Restrict, onUpdate: Restrict, map: "enderecos_ibfk_1")

  @@index([id_cliente], map: "id_cliente")
}

model orcamentos {
  id            Int       @id @default(autoincrement())
  id_usuario    Int?
  id_cliente    Int?
  id_veiculo    Int?
  etapa         String?   @db.VarChar(255)
  valor_inicial String?   @db.VarChar(255)
  valor_final   String?   @db.VarChar(255)
  data_inicio   DateTime? @db.Date
  data_termino  DateTime? @db.Date
  descricao     String?   @db.VarChar(255)
  criado_em     DateTime  @default(now()) @db.Timestamp(0)
  atualizado_em DateTime  @default(now()) @db.Timestamp(0)
  deletado_em   DateTime? @db.Timestamp(0)
  usuarios      usuarios? @relation(fields: [id_usuario], references: [id], onDelete: Restrict, onUpdate: Restrict, map: "orcamentos_ibfk_1")
  clientes      clientes? @relation(fields: [id_cliente], references: [id], onDelete: Restrict, onUpdate: Restrict, map: "orcamentos_ibfk_2")
  veiculos      veiculos? @relation(fields: [id_veiculo], references: [id], onDelete: Restrict, onUpdate: Restrict, map: "orcamentos_ibfk_3")

  @@index([id_cliente], map: "id_cliente")
  @@index([id_usuario], map: "id_usuario")
  @@index([id_veiculo], map: "id_veiculo")
}

model usuarios {
  id            Int          @id @default(autoincrement())
  nome          String?      @db.VarChar(255)
  email         String?      @db.VarChar(255)
  senha         String?      @db.VarChar(255)
  permissao     String?      @db.VarChar(255)
  ativo         Boolean?
  criado_em     DateTime     @default(now()) @db.Timestamp(0)
  atualizado_em DateTime     @default(now()) @db.Timestamp(0)
  deletado_em   DateTime?    @db.Timestamp(0)
  orcamentos    orcamentos[]
  veiculos      veiculos[]
}

model veiculos {
  id              Int            @id @default(autoincrement())
  id_usuario      Int?
  id_departamento Int?
  id_cliente      Int?
  placa           String?        @db.VarChar(255)
  modelo          String?        @db.VarChar(255)
  criado_em       DateTime       @default(now()) @db.Timestamp(0)
  atualizado_em   DateTime       @default(now()) @db.Timestamp(0)
  deletado_em     DateTime?      @db.Timestamp(0)
  orcamentos      orcamentos[]
  usuarios        usuarios?      @relation(fields: [id_usuario], references: [id], onDelete: Restrict, onUpdate: Restrict, map: "veiculos_ibfk_1")
  departamentos   departamentos? @relation(fields: [id_departamento], references: [id], onDelete: Restrict, onUpdate: Restrict, map: "veiculos_ibfk_2")
  clientes        clientes?      @relation(fields: [id_cliente], references: [id], onDelete: Restrict, onUpdate: Restrict, map: "veiculos_ibfk_3")

  @@index([id_cliente], map: "id_cliente")
  @@index([id_departamento], map: "id_departamento")
  @@index([id_usuario], map: "id_usuario")
}
